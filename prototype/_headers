# Cloudflare Pages custom headers
# https://developers.cloudflare.com/pages/configuration/headers/

# CSS — short cache so style updates propagate quickly
/css/*
  Cache-Control: public, max-age=3600, must-revalidate

/js/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=31536000, immutable

# Knowledge unit HTML pages — cache at edge, revalidate from browser
/consumer-electronics/*
  Cache-Control: public, max-age=3600, s-maxage=86400

/home/*
  Cache-Control: public, max-age=3600, s-maxage=86400

/computing/*
  Cache-Control: public, max-age=3600, s-maxage=86400

/fitness/*
  Cache-Control: public, max-age=3600, s-maxage=86400

/outdoor/*
  Cache-Control: public, max-age=3600, s-maxage=86400

/baby/*
  Cache-Control: public, max-age=3600, s-maxage=86400

/personal-care/*
  Cache-Control: public, max-age=3600, s-maxage=86400

/pet/*
  Cache-Control: public, max-age=3600, s-maxage=86400

/travel/*
  Cache-Control: public, max-age=3600, s-maxage=86400

/software/*
  Cache-Control: public, max-age=3600, s-maxage=86400

/business/*
  Cache-Control: public, max-age=3600, s-maxage=86400

/finance/*
  Cache-Control: public, max-age=3600, s-maxage=86400

/compliance/*
  Cache-Control: public, max-age=3600, s-maxage=86400

/energy/*
  Cache-Control: public, max-age=3600, s-maxage=86400

# Machine-readable discovery files — shorter cache
/catalog.json
  Cache-Control: public, max-age=3600, s-maxage=14400
  Access-Control-Allow-Origin: *

/.well-known/ai-knowledge.json
  Cache-Control: public, max-age=3600, s-maxage=14400
  Access-Control-Allow-Origin: *

/sitemap.xml
  Cache-Control: public, max-age=3600, s-maxage=14400

/llms.txt
  Cache-Control: public, max-age=3600, s-maxage=14400
  Access-Control-Allow-Origin: *

/llms-full.txt
  Cache-Control: public, max-age=3600, s-maxage=14400
  Access-Control-Allow-Origin: *

/robots.txt
  Cache-Control: public, max-age=86400

# Landing page — moderate cache
/
  Cache-Control: public, max-age=1800, s-maxage=7200

# API OpenAPI spec
/api/v1/openapi.json
  Cache-Control: public, max-age=86400
  Access-Control-Allow-Origin: *
